# ─── Copy to .env and fill in your values ────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/moi_gold"

# JWT secret (MUST be at least 32 chars in production)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# JWT expiry (e.g. 7d, 12h)
JWT_EXPIRES_IN="7d"

# Server port
PORT=4000

# Frontend URL for CORS (comma-separated for multiple, or * to allow all)
FRONTEND_URL="http://localhost:5173"

# Bcrypt rounds (10–12 recommended)
BCRYPT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10

# Behind a reverse proxy? Number of hops to trust (0 = off)
TRUST_PROXY=1

# NODE_ENV: development | production
NODE_ENV=development
